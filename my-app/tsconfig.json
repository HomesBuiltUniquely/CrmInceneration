{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@shell/*": ["./app/Components/Shared/*"],
      "@crm/lead-management/*": ["./app/Components/CrmLeadData/*"],
      "@crm/dashboard/*": ["./app/Components/CrmDashboard/*"],
      "@crm/lead-details/*": ["./app/Components/CrmLeadDetails/*"],
      "@crm/create-lead/*": ["./app/Components/CrmCreateLead/*"],
      "@crm/import-leads/*": ["./app/Components/CrmImportLeads/*"],
      "@design/workspace/*": ["./app/Components/DesignDashboard/*"],
      "@design/appointment/*": ["./app/Components/Appointment/*"],
      "@admin/panel/*": ["./app/Components/AdminPanel/*"],
      "@calendar/hub/*": ["./app/Components/HubCalender/*"],
      "@booking-token/*": ["./app/Components/BookingToken/*"],
      "@app-core/*": ["./app/Components/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
